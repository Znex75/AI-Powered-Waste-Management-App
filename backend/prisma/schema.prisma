generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id // matches Supabase user.id
  name          String
  email         String   @unique
  xpPoints      Int      @default(0)
  co2Saved      Float    @default(0.0)
  ecoCoins      Int      @default(100)
  scanCredits   Int      @default(25)
  marketCredits Int      @default(5)
  createdAt     DateTime @default(now())

  scans         Scan[]
  listings      Listing[]       @relation("SellerListings")
  purchases     Listing[]       @relation("BuyerListings")
  sentTxns      Transaction[]   @relation("TxnFrom")
  receivedTxns  Transaction[]   @relation("TxnTo")
}

model Scan {
  id          String   @id @default(uuid())
  type        String
  binCategory String
  xpReward    Int
  co2Saved    Float
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Int      @default(1)
  category    String   @default("Other")
  image       String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())

  sellerId    String
  seller      User     @relation("SellerListings", fields: [sellerId], references: [id])

  buyerId     String?
  buyer       User?    @relation("BuyerListings", fields: [buyerId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  amount      Int
  description String
  createdAt   DateTime @default(now())

  fromUserId  String?
  fromUser    User?    @relation("TxnFrom", fields: [fromUserId], references: [id])

  toUserId    String?
  toUser      User?    @relation("TxnTo", fields: [toUserId], references: [id])

  listingId   String?
}
